PORT=3000

# 阿里云 OSS
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_REGION=oss-cn-hangzhou

# DashScope（ASR + LLM 同一个 key）
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
ASR_MODEL=fun-asr
LLM_MODEL=qwen-plus

# Notion
NOTION_TOKEN=
NOTION_DATABASE_ID=

# 轮询参数（可选，有默认值）
POLL_INITIAL_DELAY_MS=5000
POLL_MAX_ATTEMPTS=30
POLL_BACKOFF_FACTOR=1.4

# 各变量的详细说明见 README.md

# 服务监听端口，一般不用改
PORT=3000
# 日志级别：debug / info / warn / error，排查问题时用 debug
LOG_LEVEL=info

# ---- 阿里云 OSS（存音频，并给转写服务提供签名 URL）----
# 必填
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
# 存储桶所在地域，如 oss-cn-shanghai
OSS_REGION=oss-cn-hangzhou
# 服务器与存储桶同地域时设为 true，上传走内网；本地开发保持 false
OSS_INTERNAL=false

# ---- 阿里云百炼 DashScope（语音转写 + 内容整理）----
# 必填，两个模型共用一个 Key
DASHSCOPE_API_KEY=
# 以下四项一般不用改
DASHSCOPE_ASR_BASE_URL=https://dashscope.aliyuncs.com
DASHSCOPE_LLM_BASE_URL=https://dashscope.aliyuncs.com
ASR_MODEL=fun-asr
LLM_MODEL=qwen-plus

# ---- Notion ----
# 必填。Integration Secret，且目标数据库要在「连接」里授权给该 Integration
NOTION_TOKEN=
# 必填。数据库 URL 里问号前面那段 32 位字符
NOTION_DATABASE_ID=

# ---- 转写结果轮询（录音很长且频繁超时时才需要调）----
# 首次轮询前等待毫秒数
POLL_INITIAL_DELAY_MS=5000
# 最多轮询次数，超过判定超时
POLL_MAX_ATTEMPTS=30
# 轮询间隔的退避倍数
POLL_BACKOFF_FACTOR=1.4
